<Window x:Class="LibraryApp.UI.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:LibraryApp.UI.ViewModels"
        xmlns:controls="clr-namespace:LibraryApp.UI.Controls"
        mc:Ignorable="d"
        Title="Import Library" Height="480" Width="680"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=vm:ImportWindowViewModel, IsDesignTimeCreatable=False}">

    <TabControl>

        <!-- ══════════════════════ TAB: Import ══════════════════════ -->
        <TabItem Header="Import">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- folder selection -->
                    <RowDefinition Height="Auto" />  <!-- options -->
                    <RowDefinition Height="Auto" />  <!-- action buttons -->
                    <RowDefinition Height="Auto" />  <!-- status text -->
                    <RowDefinition Height="Auto" />  <!-- counting indicator -->
                    <RowDefinition Height="Auto" />  <!-- segmented bar -->
                    <RowDefinition Height="Auto" />  <!-- progress counter -->
                    <RowDefinition Height="*"    />  <!-- summary / spacer -->
                    <RowDefinition Height="Auto" />  <!-- close button -->
                </Grid.RowDefinitions>

                <!-- Folder selection -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Label DockPanel.Dock="Left" Content="Folder:"
                           Width="52" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="Browse…"
                            Command="{Binding BrowseFolderCommand}"
                            Width="80" Margin="4,0,0,0"
                            IsEnabled="{Binding IsNotBusy}" />
                    <TextBox Text="{Binding FolderPath, Mode=OneWay}"
                             IsReadOnly="True" VerticalAlignment="Center" />
                </DockPanel>

                <!-- Options -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            Margin="52,0,0,8">
                    <CheckBox Content="Scan subfolders"
                              IsChecked="{Binding Recursive}"
                              IsEnabled="{Binding IsNotBusy}"
                              Margin="0,0,16,0" />
                    <CheckBox Content="Remove missing books"
                              IsChecked="{Binding RemoveMissing}"
                              IsEnabled="{Binding IsNotBusy}" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            Margin="52,0,0,10">
                    <Button Content="▶ Start Import"
                            Command="{Binding StartImportCommand}"
                            MinWidth="110" Margin="0,0,8,0" />
                    <Button Content="⏹ Cancel"
                            Command="{Binding CancelImportCommand}"
                            MinWidth="80" />
                </StackPanel>

                <!-- Status text -->
                <TextBlock Grid.Row="3"
                           Text="{Binding StatusText}"
                           Margin="0,0,0,6"
                           TextWrapping="Wrap" />

                <!-- Counting phase: indeterminate bar + live count -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6"
                            Visibility="{Binding IsCountingPhase,
                                Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True"
                                 Width="160" Height="10" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding CountedSoFar, StringFormat='Files found: {0}'}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Segmented progress bar -->
                <controls:SegmentedProgressBar
                    Grid.Row="5"
                    SegmentsSource="{Binding Segments}"
                    Total="{Binding TotalBooks}"
                    Height="24" Margin="0,0,0,4"
                    Visibility="{Binding ShowProgressBar,
                        Converter={StaticResource BoolToVisibility}}" />

                <!-- Progress counter -->
                <TextBlock Grid.Row="6" Margin="0,0,0,8"
                           Visibility="{Binding ShowProgressBar,
                               Converter={StaticResource BoolToVisibility}}">
                    <Run Text="{Binding ProcessedBooks}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalBooks}" />
                    <Run Text=" books processed" />
                </TextBlock>

                <!-- Summary panel (visible after import finishes) -->
                <Border Grid.Row="7"
                        Padding="10" Margin="0,4,0,0"
                        BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="3"
                        Visibility="{Binding HasReport,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Import Summary"
                                   FontWeight="SemiBold" Margin="0,0,0,8" />
                        <UniformGrid Rows="2" Columns="4" HorizontalAlignment="Left">
                            <TextBlock Text="Added"   Foreground="Gray" FontSize="11" />
                            <TextBlock Text="Updated" Foreground="Gray" FontSize="11" />
                            <TextBlock Text="Skipped" Foreground="Gray" FontSize="11" />
                            <TextBlock Text="Failed"  Foreground="Gray" FontSize="11" />
                            <TextBlock Text="{Binding Report.Added}"
                                       FontSize="22" FontWeight="Bold" Foreground="#4CAF50" />
                            <TextBlock Text="{Binding Report.Updated}"
                                       FontSize="22" FontWeight="Bold" Foreground="#8BC34A" />
                            <TextBlock Text="{Binding Report.Skipped}"
                                       FontSize="22" FontWeight="Bold" Foreground="#9E9E9E" />
                            <TextBlock Text="{Binding Report.Failed}"
                                       FontSize="22" FontWeight="Bold" Foreground="#F44336" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Close button -->
                <Button Grid.Row="8" Content="Close"
                        MinWidth="80" HorizontalAlignment="Right"
                        Margin="0,8,0,0"
                        Click="CloseButton_Click" />
            </Grid>
        </TabItem>

        <!-- ══════════════════════ TAB: Log (placeholder) ══════════ -->
        <TabItem Header="Log">
            <TextBlock Text="Log viewer — coming soon"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14" />
        </TabItem>

    </TabControl>
</Window>
