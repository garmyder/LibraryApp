<Window x:Class="LibraryApp.UI.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dt="clr-namespace:LibraryApp.UI.ViewModels.DesignTime"
        xmlns:controls="clr-namespace:LibraryApp.UI.Controls"
        mc:Ignorable="d"
        Title="Import Library" Height="480" Width="680"
        MinHeight="400" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        d:DataContext="{d:DesignInstance Type=dt:ImportWindowVmDesign, IsDesignTimeCreatable=True}">

    <TabControl>

        <!-- ══════════════════════ TAB: Import ══════════════════════ -->
        <TabItem Header="Import">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />  <!-- folder selection -->
                    <RowDefinition Height="Auto" />  <!-- mode + options -->
                    <RowDefinition Height="Auto" />  <!-- action buttons -->
                    <RowDefinition Height="Auto" />  <!-- status text -->
                    <RowDefinition Height="Auto" />  <!-- counting indicator -->
                    <RowDefinition Height="Auto" />  <!-- segmented bar -->
                    <RowDefinition Height="Auto" />  <!-- progress counter -->
                    <RowDefinition Height="*"    />  <!-- summary / spacer -->
                    <RowDefinition Height="Auto" />  <!-- close button -->
                </Grid.RowDefinitions>

                <!-- Folder selection -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <Label DockPanel.Dock="Left" Content="Folder:"
                           Width="52" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="Browse…"
                            Command="{Binding BrowseFolderCommand}"
                            Width="80" Margin="4,0,0,0" Height="20"
                            IsEnabled="{Binding IsNotBusy}"
                            ToolTip="Select the root folder to scan for book files" />
                    <TextBox Text="{Binding FolderPath, Mode=OneWay}"
                             IsReadOnly="True" VerticalAlignment="Center" Height="20"
                             ToolTip="Root folder that will be scanned for books" />
                </DockPanel>

                <!-- Mode (radio) + Options (checkboxes) — two vertical columns -->
                <Border Grid.Row="1" Margin="52,0,0,10"
                        Padding="8,6" BorderBrush="#BDBDBD"
                        BorderThickness="1" CornerRadius="3"
                        IsEnabled="{Binding IsNotBusy}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Import mode radio buttons (vertical) -->
                    <StackPanel Grid.Column="0" Orientation="Vertical">

                        <RadioButton Content="Recreate"
                                     IsChecked="{Binding ImportMode,
                                         Converter={StaticResource EnumToBool},
                                         ConverterParameter=Recreate}"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,0,8">
                            <RadioButton.ToolTip>
                                <ToolTip MaxWidth="260">
                                    <TextBlock TextWrapping="Wrap">
                                        Clears all authors, books and series, then
                                        imports from scratch. Reference tables
                                        (genres, languages) are preserved.
                                    </TextBlock>
                                </ToolTip>
                            </RadioButton.ToolTip>
                        </RadioButton>

                        <RadioButton Content="Update"
                                     IsChecked="{Binding ImportMode,
                                         Converter={StaticResource EnumToBool},
                                         ConverterParameter=Update}"
                                     VerticalContentAlignment="Center">
                            <RadioButton.ToolTip>
                                <ToolTip MaxWidth="260">
                                    <TextBlock TextWrapping="Wrap">
                                        Adds new books and authors, updates existing
                                        records, and optionally removes books no
                                        longer present on disk.
                                    </TextBlock>
                                </ToolTip>
                            </RadioButton.ToolTip>
                        </RadioButton>

                    </StackPanel>

                    <!-- Vertical separator -->
                    <Separator Grid.Column="1"
                               Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Width="1" HorizontalAlignment="Center" />

                    <!-- Checkboxes (vertical) -->
                    <StackPanel Grid.Column="2" Orientation="Vertical"
                                VerticalAlignment="Center">

                        <CheckBox Content="Scan subfolders"
                                  IsChecked="{Binding Recursive}"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,0,8"
                                  ToolTip="Recursively scan all subdirectories of the selected folder" />

                        <CheckBox Content="Remove missing"
                                  IsChecked="{Binding RemoveMissing}"
                                  IsEnabled="{Binding IsRemoveMissingAvailable}"
                                  VerticalContentAlignment="Center">
                            <CheckBox.ToolTip>
                                <ToolTip MaxWidth="260">
                                    <TextBlock TextWrapping="Wrap">
                                        Remove books from the database whose files
                                        are no longer found on disk.
                                        Available in Update mode only.
                                    </TextBlock>
                                </ToolTip>
                            </CheckBox.ToolTip>
                        </CheckBox>

                    </StackPanel>
                </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            Margin="52,5,0,10">
                    <Button Content="▶ Import"
                            Command="{Binding StartImportCommand}"
                            MinWidth="80" Margin="0,0,8,0"
                            ToolTip="Start the import process" />
                    <Button Content="⏹ Cancel"
                            Command="{Binding CancelImportCommand}"
                            MinWidth="80"
                            ToolTip="Cancel the running import and roll back all changes" />
                </StackPanel>

                <!-- Status text -->
                <TextBlock Grid.Row="3"
                           Text="{Binding StatusText}"
                           Margin="0,5,0,6"
                           TextWrapping="Wrap" />

                <!-- Counting phase: indeterminate bar + live count -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6"
                            Visibility="{Binding IsCountingPhase,
                                Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True"
                                 Width="160" Height="10" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding CountedSoFar, StringFormat='Files found: {0}'}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Segmented progress bar -->
                <controls:SegmentedProgressBar
                    Grid.Row="5"
                    SegmentsSource="{Binding Segments}"
                    Total="{Binding TotalBooks}"
                    Height="50" Margin="0,0,0,4"
                    Visibility="{Binding ShowProgressBar,
                        Converter={StaticResource BoolToVisibility}}" />

                <!-- Progress counter -->
                <TextBlock Grid.Row="6" Margin="0,0,0,8"
                           Visibility="{Binding ShowProgressBar,
                               Converter={StaticResource BoolToVisibility}}">
                    <Run Text="{Binding ProcessedBooks}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalBooks}" />
                    <Run Text=" books processed" />
                </TextBlock>

                <!-- Import Summary (compact) -->
                <Border Grid.Row="7"
                        Padding="8,6" Margin="0,4,0,0"
                        BorderBrush="#BDBDBD" BorderThickness="1" CornerRadius="3"
                        VerticalAlignment="Top"
                        Visibility="{Binding HasReport,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Import Summary"
                                   FontWeight="SemiBold" Margin="0,0,0,6" />
                        <UniformGrid Rows="2" Columns="4" HorizontalAlignment="Left">
                            <TextBlock Text="Added"   Foreground="Gray" FontSize="11" />
                            <TextBlock Text="Updated" Foreground="Gray" FontSize="11" Margin="0,0,10,0" />
                            <TextBlock Text="Skipped" Foreground="Gray" FontSize="11" />
                            <TextBlock Text="Failed"  Foreground="Gray" FontSize="11" />
                            <TextBlock Text="{Binding Report.Added}"
                                       FontSize="15" FontWeight="Bold" Foreground="#4CAF50" />
                            <TextBlock Text="{Binding Report.Updated}"
                                       FontSize="15" FontWeight="Bold" Foreground="#8BC34A" />
                            <TextBlock Text="{Binding Report.Skipped}"
                                       FontSize="15" FontWeight="Bold" Foreground="#9E9E9E" />
                            <TextBlock Text="{Binding Report.Failed}"
                                       FontSize="15" FontWeight="Bold" Foreground="#F44336" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Close button -->
                <Button Grid.Row="8" Content="Close"
                        MinWidth="80" HorizontalAlignment="Right"
                        Margin="0,8,0,0"
                        Click="CloseButton_Click"
                        ToolTip="Close this window" />
            </Grid>
        </TabItem>

        <!-- ══════════════════════ TAB: Log ══════════════════════════ -->
        <TabItem Header="Log">
            <TextBlock Text="Log viewer — coming soon"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14" />
        </TabItem>

    </TabControl>
</Window>
