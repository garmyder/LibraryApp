<Window x:Class="LibraryApp.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:LibraryApp.UI.ViewModels"
        xmlns:data="clr-namespace:System.Windows.Data;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="My Library" Height="600" Width="1000"
        MinHeight="400" MinWidth="600"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel, IsDesignTimeCreatable=False}">

    <DockPanel LastChildFill="True">

        <!-- ═══════════════════════ MAIN MENU ═══════════════════════ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Library…"
                          Command="{Binding OpenLibraryCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuItem_Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Add Author…" />
                <MenuItem Header="_Add Book…" />
                <Separator />
                <MenuItem Header="_Delete" />
            </MenuItem>
            <MenuItem Header="_Books">
                <MenuItem Header="_Search…" />
                <MenuItem Header="_Export…" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Refresh"
                          Command="{Binding LoadAuthorsCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About…" />
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════ STATUS BAR ═══════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator />
            <!-- Import progress bar (indeterminate, visible only while importing) -->
            <StatusBarItem>
                <ProgressBar Width="120" Height="12"
                             IsIndeterminate="True"
                             Visibility="{Binding IsImporting,
                                 Converter={StaticResource BoolToVisibility}}" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ItemCountText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ═══════════════════════ TAB CONTROL ═══════════════════════ -->
        <TabControl Margin="2">

            <!-- ─────────────── TAB: Authors ─────────────── -->
            <TabItem Header="Authors">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" MinWidth="150" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="200" />
                    </Grid.ColumnDefinitions>

                    <!-- ── LEFT PANEL ── -->
                    <DockPanel Grid.Column="0">

                        <!-- Author filter box -->
                        <TextBox DockPanel.Dock="Top"
                                 Margin="2" Height="26"
                                 Text="{Binding AuthorFilter, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filter authors by name" />

                        <ListView x:Name="AuthorsListView"
                                  Margin="2,0,2,2"
                                  ItemsSource="{Binding AuthorsView}"
                                  d:ItemsSource="{d:SampleData ItemCount=4, Type=vm:AuthorListItemVm}"
                                  SelectedItem="{Binding SelectedAuthor}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Author" Width="210">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:AuthorListItemVm}">
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="#" Width="40">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type vm:AuthorListItemVm}">
                                                <TextBlock Text="{Binding BookCount}" HorizontalAlignment="Right" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>

                    <!-- ── VERTICAL SPLITTER ── -->
                    <GridSplitter Grid.Column="1" Width="5"
                                  HorizontalAlignment="Stretch"
                                  ResizeBehavior="PreviousAndNext"
                                  Background="LightGray" ShowsPreview="True" />

                    <!-- ── RIGHT PANEL ── -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="150" />

                            <RowDefinition Height="Auto" />

                            <RowDefinition Height="180" MinHeight="60" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="BooksDataGrid"
                                  Grid.Row="0" Margin="2,2,2,0"
                                  ItemsSource="{Binding BooksView}"
                                  SelectedItem="{Binding SelectedBook}"
                                  d:ItemsSource="{d:SampleData ItemCount=5, Type=vm:BookFlatItemVm}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  EnableRowVirtualization="True"
                                  RowHeaderWidth="0"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F5F5F5"
                                  GridLinesVisibility="None">

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rate 1 ★" Command="{Binding SetRateFromStringCommand}" CommandParameter="1" />
                                    <MenuItem Header="Rate 2 ★★" Command="{Binding SetRateFromStringCommand}" CommandParameter="2" />
                                    <MenuItem Header="Rate 3 ★★★" Command="{Binding SetRateFromStringCommand}" CommandParameter="3" />
                                    <MenuItem Header="Rate 4 ★★★★" Command="{Binding SetRateFromStringCommand}" CommandParameter="4" />
                                    <MenuItem Header="Rate 5 ★★★★★" Command="{Binding SetRateFromStringCommand}" CommandParameter="5" />
                                    <MenuItem Header="Clear Rating" Command="{Binding ClearRateCommand}" />
                                    <Separator />
                                    <MenuItem Header="Toggle Read/Unread" Command="{Binding ToggleReadCommand}" />
                                    <Separator />
                                    <MenuItem Header="Delete" Command="{Binding DeleteSelectedCommand}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <StackPanel d:DataContext="{d:DesignInstance Type=data:CollectionViewGroup, IsDesignTimeCreatable=False}">
                                                            <Border Background="#E8EAF6" BorderBrush="#BDBDBD" BorderThickness="0,0,0,1" Padding="6,4">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <CheckBox IsThreeState="True" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                              IsChecked="{Binding DataContext.AllBooksChecked, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=OneWay}"
                                                                              Command="{Binding DataContext.ToggleAllBooksCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' — {0} books'}" Foreground="Gray" VerticalAlignment="Center"
                                                                               Margin="2,0,0,0" />
                                                                </StackPanel>
                                                            </Border>
                                                            <ItemsPresenter />
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>

                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="GroupItem">
                                                        <Border d:DataContext="{d:DesignInstance Type=data:CollectionViewGroup, IsDesignTimeCreatable=False}">
                                                            <Expander IsExpanded="True" Background="#F5F5F5">
                                                                <Expander.Header>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <CheckBox IsThreeState="True" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                                  Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                                  CommandParameter="{Binding}">
                                                                            <CheckBox.IsChecked>
                                                                                <MultiBinding Converter="{StaticResource GroupIsChecked}" Mode="OneWay">
                                                                                    <Binding Path="Items" />
                                                                                    <Binding Path="DataContext.SelectionVersion"
                                                                                             RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                                                                                </MultiBinding>
                                                                            </CheckBox.IsChecked>
                                                                        </CheckBox>
                                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" Foreground="Gray" VerticalAlignment="Center"
                                                                                   Margin="2,0,0,0" />
                                                                    </StackPanel>
                                                                </Expander.Header>
                                                                <Border Margin="50,0,0,2" BorderBrush="#BDBDBD" BorderThickness="1,0,0,0" Padding="4,0,0,0">
                                                                    <ItemsPresenter />
                                                                </Border>
                                                            </Expander>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="30" MinWidth="30" MaxWidth="30" CanUserSort="False" CanUserResize="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="✓" Width="28" MinWidth="28" MaxWidth="28" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="✓" Foreground="#2E7D32" HorizontalAlignment="Center"
                                                       Visibility="{Binding Read, Converter={StaticResource BoolToVisibility}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Title" Width="*" MinWidth="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="{Binding Title}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="#" Width="40" MinWidth="40" MaxWidth="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="{Binding SeriesNumber}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Lang" Width="60" MinWidth="60" MaxWidth="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="{Binding Language}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Format" Width="60" MinWidth="60" MaxWidth="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="{Binding Format}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Rating" Width="90" MinWidth="90" MaxWidth="90" CanUserSort="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <ItemsControl ItemsSource="{Binding Rate, Converter={StaticResource StarRating}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="★" FontSize="12" Foreground="{Binding Converter={StaticResource BoolToStarBrush}}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Genre" Width="*" MinWidth="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type vm:BookFlatItemVm}">
                                            <TextBlock Text="{Binding Genre}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <GridSplitter Grid.Row="1" Height="5"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeBehavior="PreviousAndNext"
                                      Background="LightGray" ShowsPreview="True" />

                        <Border Grid.Row="2" Margin="2,0,2,2"
                                BorderBrush="LightGray" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock Padding="6" TextWrapping="Wrap"
                                           Foreground="Gray"
                                           Text="{Binding BookDetail}" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Books">
                <TextBlock Text="Books view — coming soon"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="Gray" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>