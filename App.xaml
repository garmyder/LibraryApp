<Application x:Class="LibraryApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LibraryApp.UI.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:StarRatingConverter x:Key="StarRating" />
        <converters:BoolToStarBrushConverter x:Key="BoolToStarBrush" />
        <converters:GroupIsCheckedConverter x:Key="GroupIsChecked" />
        <converters:EnumToBoolConverter x:Key="EnumToBool" />
    </Application.Resources>
</Application>
